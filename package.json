{
  "name": "nizamcore",
  "version": "1.0.0",
  "description": "Backend Sistem Informasi Akademik NizamCore",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "ts-node src/db/migrate.ts",
    "db:seed": "ts-node src/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "express": "^4.19.2",
    "drizzle-orm": "^0.31.0",
    "postgres": "^3.4.4",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "drizzle-kit": "^0.22.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0"
  }
}
